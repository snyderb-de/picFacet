<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Main app: unsandboxed for direct-distribution MVP.
         Still uses App Group to share the requests folder with the extension.
         Re-enable sandbox + user-selected files + bookmarks for App Store build. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.picfacet.shared</string>
    </array>
</dict>
</plist>
