<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>PicFacet</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 PicFacet. All rights reserved.</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- NSServices: each entry becomes a right-click item in Finder for image files.
         NSSendFileTypes restricts the service to image UTIs so it only appears
         when an image (or images) is selected. NSServiceDescription opts in to
         being shown as a Quick Action (top-level in Finder on macOS 10.14+). -->
    <key>NSServices</key>
    <array>

        <!-- Chooser: opens the PicFacet picker window for the selected images. -->
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet…</string></dict>
            <key>NSMessage</key><string>picFacetChooser</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>

        <!-- Convert -->
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to JPEG</string></dict>
            <key>NSMessage</key><string>convertToJPEG</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key>
            <array>
                <string>public.image</string>
            </array>
            <key>NSRequiredContext</key><dict><key>NSTextContent</key><string>None</string></dict>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to PNG</string></dict>
            <key>NSMessage</key><string>convertToPNG</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to WebP</string></dict>
            <key>NSMessage</key><string>convertToWebP</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to TIFF</string></dict>
            <key>NSMessage</key><string>convertToTIFF</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to GIF</string></dict>
            <key>NSMessage</key><string>convertToGIF</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to BMP</string></dict>
            <key>NSMessage</key><string>convertToBMP</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Convert to HEIC</string></dict>
            <key>NSMessage</key><string>convertToHEIC</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>

        <!-- Resize -->
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Resize 25%</string></dict>
            <key>NSMessage</key><string>resize25</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Resize 50%</string></dict>
            <key>NSMessage</key><string>resize50</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Resize 75%</string></dict>
            <key>NSMessage</key><string>resize75</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>

        <!-- DPI -->
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Set DPI 72</string></dict>
            <key>NSMessage</key><string>dpi72</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Set DPI 150</string></dict>
            <key>NSMessage</key><string>dpi150</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Set DPI 300</string></dict>
            <key>NSMessage</key><string>dpi300</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key><dict><key>default</key><string>PicFacet: Set DPI 600</string></dict>
            <key>NSMessage</key><string>dpi600</string>
            <key>NSPortName</key><string>PicFacet</string>
            <key>NSSendFileTypes</key><array><string>public.image</string></array>
        </dict>
    </array>
</dict>
</plist>
